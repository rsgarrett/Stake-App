{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "(auth)",
    "(dashboard)",
    "api",
    "auth-check",
    "calendar",
    "communication",
    "conferences",
    "dashboard",
    "export",
    "google-sheets",
    "import",
    "interviews",
    "layout",
    "leadership",
    "meetings",
    "missionary",
    "modules",
    "register",
    "settings",
    "temple",
    "training",
    "welfare",
    "youth",
    "supabase"
  ]
}


